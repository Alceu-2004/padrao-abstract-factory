' Ligações corretas (sem ambiguidade)
BebidaQuenteFactory ..> CafeQuente
BebidaQuenteFactory ..> ChaQuente

BebidaFriaFactory ..> CafeGelado
BebidaFriaFactory ..> ChaGelado

@enduml